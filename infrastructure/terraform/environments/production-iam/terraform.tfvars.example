# environments/production-iam/terraform.tfvars.example
#
# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars — it contains account-specific values.
# The .gitignore should exclude *.tfvars files.

development_account_id = "444083008220"
staging_account_id     = "577449503821"
production_account_id  = "052997916327"

# The gds-users org root account. Replace with your actual org account ID.
gds_users_account_arn = "arn:aws:iam::REPLACE_WITH_GDS_USERS_ACCOUNT_ID:root"

role_prefix = "gds-aidr"

# Only you and your LM should be listed here.
# These are the IAM user ARNs in the gds-users account.
admin_trusted_arns = [
  "arn:aws:iam::REPLACE_WITH_GDS_USERS_ACCOUNT_ID:user/victoria.mckinney",
  "arn:aws:iam::REPLACE_WITH_GDS_USERS_ACCOUNT_ID:user/REPLACE_WITH_LM_USERNAME"
]

# Lock GitHub Actions OIDC to the main branch of the infrastructure repo.
# This means only merged PRs can trigger terraform apply.
github_oidc_allowed_subjects = [
  "repo:alphagov/gds-aidr-infrastructure:ref:refs/heads/main"
]

max_session_duration = 14400
